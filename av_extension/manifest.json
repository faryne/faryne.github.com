{
    "manifest_version": 3,
    "name": "AV 女優換圖",
    "version": "1.2.0",
    "description": "自動將網頁中的圖片隨機替換為 AV 女優圖庫圖片（純屬娛樂）。",
    "author": "Faryne",
    "host_permissions": [
        "https://faryne.dev/"
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "av.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {}
}
